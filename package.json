{
  "name": "time-tracker",
  "version": "1.0.0",
  "description": "Standalone Time Tracker for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "pack": "electron-builder --mac --dir"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.timetracker.app",
    "productName": "Time Tracker",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "src/assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "allowScripts": {
    "electron@28.3.3": true
  }
}
